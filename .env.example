# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-random-string

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── Domain & Admin ─────────────────────────────────────────────────────────────
ALLOWED_DOMAIN=dubai.bits-pilani.ac.in
ADMIN_EMAIL=acm@dubai.bits-pilani.ac.in

# ── Google Drive Sync ──────────────────────────────────────────────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Type: Web Application, Redirect URI: http://localhost:4000/callback
GDRIVE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GDRIVE_CLIENT_SECRET=YOUR_CLIENT_SECRET
# Run "node gdrive-setup.js" to get this token after setting the above two
GDRIVE_REFRESH_TOKEN=
# Sync interval in ms (default: 60000 = 1 min)
# DRIVE_SYNC_INTERVAL=60000
