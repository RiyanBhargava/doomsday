<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DOOMSDAY — Mission Control</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <style>
    body { overflow: hidden; }
    .gameboard-container {
      position: relative;
      width: 100vw;
      height: 100vh;
    }
    .gameboard-bg {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
      z-index: 0;
    }
    .gameboard-svg {
      position: absolute;
      top: 18%;
      left: 50%;
      transform: translateX(-50%);
      width: 55%;
      height: 55%;
      z-index: 1;
    }

    /* Region styles */
    .region-path {
      fill: rgba(0, 255, 65, 0.06);
      stroke: #00ff41;
      stroke-width: 2;
      stroke-dasharray: 8 4;
      cursor: pointer;
      transition: fill 0.4s, stroke-width 0.3s;
    }
    .region-path:hover {
      fill: rgba(0, 255, 65, 0.15);
      stroke-width: 3;
    }
    .region-path.completed {
      fill: rgba(0, 255, 65, 0.3);
      stroke: #00ff41;
      stroke-width: 3;
      stroke-dasharray: none;
    }

    .region-label {
      font-family: 'Orbitron', sans-serif;
      font-size: 28px;
      font-weight: 900;
      fill: #00ff41;
      text-anchor: middle;
      pointer-events: none;
      filter: drop-shadow(0 0 10px rgba(0,255,65,0.7));
    }

    .region-progress {
      font-family: 'Orbitron', sans-serif;
      font-size: 12px;
      fill: #00cc33;
      text-anchor: middle;
      pointer-events: none;
    }

    .neutralized-stamp {
      font-family: 'Orbitron', sans-serif;
      font-size: 20px;
      font-weight: 900;
      fill: #00ff41;
      text-anchor: middle;
      opacity: 0;
      pointer-events: none;
      transform-origin: center;
    }
    .neutralized-stamp.show {
      opacity: 1;
      animation: stampIn 0.5s ease;
    }

    @keyframes stampIn {
      0% { opacity: 0; transform: scale(3) rotate(-15deg); }
      60% { opacity: 1; transform: scale(1.1) rotate(-12deg); }
      100% { opacity: 1; transform: scale(1) rotate(-12deg); }
    }

    /* Pulse rings */
    .pulse-ring {
      fill: none;
      stroke: #00ff41;
      stroke-width: 2;
      opacity: 0;
      pointer-events: none;
    }
    .pulse-ring.active {
      animation: pulseRing 2s ease-out infinite;
    }
    @keyframes pulseRing {
      0% { r: 5; opacity: 0.8; stroke-width: 2; }
      100% { r: 30; opacity: 0; stroke-width: 0.5; }
    }

    .landmark-dot {
      fill: #00ff41;
      pointer-events: none;
      filter: drop-shadow(0 0 6px rgba(0,255,65,0.8));
    }

    /* Crack/burn decorations */
    .crack-line {
      stroke: rgba(0,255,65,0.15);
      stroke-width: 1;
      fill: none;
      pointer-events: none;
    }

    /* HUD */
    .gameboard-hud {
      position: absolute;
      top: 0; left: 0; right: 0;
      z-index: 10;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 16px 24px;
      background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 70%, transparent 100%);
      pointer-events: none;
    }
    .gameboard-hud > * { pointer-events: all; }

    .hud-left { display: flex; align-items: center; gap: 16px; }
    .hud-nav a {
      font-family: 'Orbitron', sans-serif;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #666;
      margin-right: 14px;
    }
    .hud-nav a:hover { color: #00ff41; text-shadow: 0 0 8px rgba(0,255,65,0.5); }

    .hud-center { text-align: center; }
    .hud-right { text-align: right; }
    .hud-team-name {
      font-family: 'Orbitron', sans-serif;
      font-size: 11px;
      color: #666;
      letter-spacing: 2px;
    }
    .hud-score {
      font-family: 'Orbitron', sans-serif;
      font-size: 24px;
      font-weight: 900;
      color: #00ff41;
      text-shadow: 0 0 10px rgba(0,255,65,0.5);
    }

    .hud-logout {
      background: none;
      border: none;
      color: #444;
      font-family: 'Orbitron', sans-serif;
      font-size: 9px;
      letter-spacing: 1px;
      cursor: pointer;
      text-transform: uppercase;
      margin-top: 4px;
    }
    .hud-logout:hover { color: #ff0040; }

    /* Question Slide Panel for gameboard */
    .question-panel {
      position: fixed;
      top: 0; right: -650px;
      width: 640px;
      max-width: 95vw;
      height: 100vh;
      background: rgba(5,5,5,0.97);
      border-left: 2px solid #004d00;
      z-index: 100;
      overflow-y: auto;
      transition: right 0.4s cubic-bezier(.22,.61,.36,1);
      padding: 0;
      backdrop-filter: blur(10px);
    }
    .question-panel.open { right: 0; }

    .panel-backdrop {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.4);
      z-index: 99;
      display: none;
    }
    .panel-backdrop.open { display: block; }

    .panel-header {
      padding: 20px 24px;
      border-bottom: 1px solid #1a1a1a;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      background: rgba(5,5,5,0.98);
      z-index: 2;
    }
    .panel-header h2 {
      font-size: 16px;
      margin: 0;
    }
    .panel-close {
      background: none;
      border: none;
      color: #666;
      font-size: 24px;
      cursor: pointer;
    }
    .panel-close:hover { color: #00ff41; }

    .panel-body { padding: 20px 24px; }

    /* Question detail view */
    .question-detail {
      display: none;
    }
    .question-detail.active { display: block; }

    .question-detail-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .back-to-list {
      background: none;
      border: none;
      color: #666;
      font-size: 18px;
      cursor: pointer;
      padding: 4px;
    }
    .back-to-list:hover { color: #00ff41; }

    .attachments-row, .links-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin: 12px 0;
    }
    .attachment-btn, .link-btn {
      font-family: 'Orbitron', sans-serif;
      font-size: 9px;
      padding: 6px 12px;
      border: 1px solid #333;
      background: transparent;
      color: #ccc;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .attachment-btn:hover { border-color: #00ff41; color: #00ff41; }
    .link-btn { border-color: #004d00; color: #00cc33; }
    .link-btn:hover { border-color: #00ff41; color: #00ff41; }

    .hint-box {
      border: 1px solid #1a1a1a;
      padding: 12px;
      margin: 8px 0;
      background: #080808;
    }
    .hint-reveal-btn {
      font-family: 'Orbitron', sans-serif;
      font-size: 9px;
      padding: 6px 14px;
      border: 1px solid #664400;
      background: transparent;
      color: #ffcc00;
      cursor: pointer;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .hint-reveal-btn:hover { background: rgba(255,204,0,0.1); }
    .hint-text { color: #ffcc00; margin-top: 8px; font-size: 13px; }
    .hint-penalty { color: #666; font-size: 10px; }

    .answer-section {
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid #1a1a1a;
    }
    .answer-toggle {
      display: flex;
      gap: 8px;
      margin-bottom: 10px;
    }
    .answer-toggle button {
      font-family: 'Orbitron', sans-serif;
      font-size: 9px;
      padding: 4px 12px;
      border: 1px solid #333;
      background: transparent;
      color: #666;
      cursor: pointer;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .answer-toggle button.active { border-color: #00ff41; color: #00ff41; }

    .submit-row {
      display: flex;
      gap: 10px;
      margin-top: 10px;
      align-items: center;
    }
    .attempt-info {
      font-size: 11px;
      color: #666;
      margin-top: 8px;
    }

    .solved-banner {
      background: rgba(0,255,65,0.1);
      border: 1px solid #004d00;
      padding: 12px;
      text-align: center;
      font-family: 'Orbitron', sans-serif;
      font-size: 12px;
      color: #00ff41;
      letter-spacing: 2px;
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <div class="gameboard-container" id="gameboard">
    <!-- Background Image -->
    <img src="/images/doom_bg.jpg" alt="Doomsday" class="gameboard-bg" id="bg-img">

    <!-- SVG Map Overlay -->
    <svg class="gameboard-svg" id="map-svg" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid meet">
      <defs>
        <filter id="glow">
          <feGaussianBlur stdDeviation="3" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
        <filter id="roughEdge">
          <feTurbulence type="turbulence" baseFrequency="0.02" numOctaves="3" result="turbulence"/>
          <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="4"/>
        </filter>
      </defs>

      <!-- Decorative cracks -->
      <g class="cracks-layer" opacity="0.25">
        <path class="crack-line" d="M400,0 L395,150 L405,300 L390,450 L400,600"/>
        <path class="crack-line" d="M0,300 L200,290 L400,310 L600,295 L800,300"/>
        <path class="crack-line" d="M150,50 L200,180 L160,320"/>
        <path class="crack-line" d="M650,60 L620,200 L670,340"/>
      </g>

      <!-- AI Region — Top Left -->
      <g class="region-group" data-category="AI">
        <path class="region-path" id="region-AI" d="
          M15,15 L340,12 C360,14 375,30 380,55
          L385,140 C383,180 370,210 345,240
          L300,270 C270,285 230,280 195,270
          L100,240 C60,225 35,200 20,165
          L15,80 Z
        " filter="url(#roughEdge)"/>
        <circle class="landmark-dot" cx="190" cy="140" r="4"/>
        <circle class="pulse-ring active" cx="190" cy="140" r="5" id="pulse-AI"/>
        <text class="region-label" x="190" y="130" filter="url(#glow)">AI</text>
        <text class="region-progress" x="190" y="158" id="progress-AI">0/0</text>
        <text class="neutralized-stamp" x="190" y="175" id="stamp-AI" transform="rotate(-12,190,175)">NEUTRALIZED</text>
      </g>

      <!-- CP Region — Top Right -->
      <g class="region-group" data-category="CP">
        <path class="region-path" id="region-CP" d="
          M460,12 L785,15 L785,165 C780,200 760,225 730,245
          L660,275 C625,285 585,280 555,265
          L490,230 C460,210 440,180 425,150
          L415,80 C415,45 430,20 460,12 Z
        " filter="url(#roughEdge)"/>
        <circle class="landmark-dot" cx="610" cy="140" r="4"/>
        <circle class="pulse-ring active" cx="610" cy="140" r="5" id="pulse-CP"/>
        <text class="region-label" x="610" y="130" filter="url(#glow)">CP</text>
        <text class="region-progress" x="610" y="158" id="progress-CP">0/0</text>
        <text class="neutralized-stamp" x="610" y="175" id="stamp-CP" transform="rotate(-12,610,175)">NEUTRALIZED</text>
      </g>

      <!-- HEX Region — Bottom Left -->
      <g class="region-group" data-category="HEX">
        <path class="region-path" id="region-HEX" d="
          M15,330 L100,310 C150,300 210,310 270,325
          L345,350 C375,365 390,390 385,425
          L370,500 C355,540 325,565 280,580
          L150,588 C90,590 45,588 15,585 Z
        " filter="url(#roughEdge)"/>
        <circle class="landmark-dot" cx="195" cy="450" r="4"/>
        <circle class="pulse-ring active" cx="195" cy="450" r="5" id="pulse-HEX"/>
        <text class="region-label" x="195" y="440" filter="url(#glow)">HEX</text>
        <text class="region-progress" x="195" y="468" id="progress-HEX">0/0</text>
        <text class="neutralized-stamp" x="195" y="485" id="stamp-HEX" transform="rotate(-12,195,485)">NEUTRALIZED</text>
      </g>

      <!-- DEV Region — Bottom Right -->
      <g class="region-group" data-category="DEV">
        <path class="region-path" id="region-DEV" d="
          M455,325 L540,310 C590,300 645,305 700,320
          L760,345 C780,360 785,390 785,430
          L785,585 L550,588 C490,588 440,575 410,550
          L395,500 C385,465 390,430 405,395
          L430,355 C440,338 447,330 455,325 Z
        " filter="url(#roughEdge)"/>
        <circle class="landmark-dot" cx="605" cy="450" r="4"/>
        <circle class="pulse-ring active" cx="605" cy="450" r="5" id="pulse-DEV"/>
        <text class="region-label" x="605" y="440" filter="url(#glow)">DEV</text>
        <text class="region-progress" x="605" y="468" id="progress-DEV">0/0</text>
        <text class="neutralized-stamp" x="605" y="485" id="stamp-DEV" transform="rotate(-12,605,485)">NEUTRALIZED</text>
      </g>

      <!-- Connection lines between regions -->
      <g opacity="0.2">
        <line x1="380" y1="240" x2="420" y2="240" stroke="#00ff41" stroke-width="0.5" stroke-dasharray="4 8"/>
        <line x1="345" y1="280" x2="345" y2="310" stroke="#00ff41" stroke-width="0.5" stroke-dasharray="4 8"/>
        <line x1="455" y1="280" x2="455" y2="310" stroke="#00ff41" stroke-width="0.5" stroke-dasharray="4 8"/>
      </g>
    </svg>

    <!-- HUD Overlay -->
    <div class="gameboard-hud">
      <div class="hud-left">
        <a href="/" style="font-family:Orbitron;font-size:14px;font-weight:900;color:#00ff41;text-shadow:0 0 10px rgba(0,255,65,0.5);letter-spacing:3px;text-decoration:none;">DOOMSDAY</a>
        <div class="hud-nav">
          <a href="/leaderboard.html">Leaderboard</a>
          <a href="/dashboard.html">Dashboard</a>
        </div>
      </div>
      <div class="hud-center">
        <div class="countdown-timer" id="countdown">00:00:00</div>
      </div>
      <div class="hud-right">
        <div class="hud-team-name" id="team-name">—</div>
        <div class="hud-score" id="team-score">0</div>
        <button class="hud-logout" onclick="logout()">Logout</button>
      </div>
    </div>
  </div>

  <!-- Question Panel (slide from right) -->
  <div class="panel-backdrop" id="panel-backdrop"></div>
  <div class="question-panel" id="question-panel">
    <div class="panel-header">
      <h2 id="panel-category-title">Category</h2>
      <button class="panel-close" onclick="closePanel()">&times;</button>
    </div>
    <div class="panel-body">
      <!-- Question List -->
      <div id="question-list"></div>

      <!-- Question Detail -->
      <div id="question-detail" class="question-detail">
        <div class="question-detail-header">
          <button class="back-to-list" onclick="showQuestionList()">&#8592;</button>
          <h3 id="detail-title" style="font-size:14px;margin:0;"></h3>
          <span id="detail-points" class="badge badge-green" style="margin-left:auto;"></span>
        </div>

        <div id="detail-solved-banner" class="solved-banner" style="display:none;">
          &#10003; SOLVED
        </div>

        <div id="detail-body" class="markdown-body"></div>

        <div id="detail-attachments" class="attachments-row"></div>
        <div id="detail-links" class="links-row"></div>

        <div id="detail-hints"></div>

        <div id="answer-section" class="answer-section">
          <div class="answer-toggle">
            <button class="active" onclick="setAnswerMode('text', this)">Text</button>
            <button onclick="setAnswerMode('code', this)">Code</button>
          </div>
          <input type="text" class="input-field" id="answer-text-input" placeholder="Enter your answer...">
          <textarea class="code-editor" id="answer-code-input" placeholder="// Paste or type your answer..." style="display:none;"></textarea>
          <div class="submit-row">
            <button class="btn btn-primary btn-small" onclick="submitAnswer()" id="submit-btn">Submit</button>
            <div class="spinner" id="submit-spinner" style="display:none;"></div>
          </div>
          <div class="attempt-info" id="attempt-info"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Announcement Bar -->
  <div class="announcement-bar" id="announcement-bar"></div>

  <!-- Toast Container -->
  <div class="toast-container" id="toast-container"></div>

  <!-- Confetti Container -->
  <div class="confetti-container" id="confetti-container"></div>

  <!-- Sound Toggle -->
  <button class="sound-toggle" id="sound-toggle" onclick="toggleSound()" title="Toggle sounds">&#128264;</button>

  <!-- External Libraries -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>

  <script>
    // ═══════════════════════════════════════════════════════════════════════════
    // GAMEBOARD CONTROLLER
    // ═══════════════════════════════════════════════════════════════════════════

    let teamData = null;
    let progressData = {};
    let currentCategory = null;
    let currentQuestionId = null;
    let soundEnabled = false;
    const socket = io();

    // ── Audio (Web Audio API — simple tones) ────────────────────────────────
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    function playTone(freq, duration, type = 'sine') {
      if (!soundEnabled) return;
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = type;
      osc.frequency.value = freq;
      gain.gain.value = 0.1;
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.start();
      osc.stop(audioCtx.currentTime + duration);
    }

    function playSuccess() { playTone(523, 0.15); setTimeout(() => playTone(659, 0.15), 100); setTimeout(() => playTone(784, 0.3), 200); }
    function playFail() { playTone(200, 0.3, 'sawtooth'); }
    function playClick() { playTone(800, 0.05); }

    function toggleSound() {
      soundEnabled = !soundEnabled;
      const btn = document.getElementById('sound-toggle');
      btn.classList.toggle('active', soundEnabled);
      btn.innerHTML = soundEnabled ? '&#128266;' : '&#128264;';
      if (soundEnabled) audioCtx.resume();
    }

    // ── Init ──────────────────────────────────────────────────────────────────
    async function init() {
      const res = await fetch('/auth/me');
      const data = await res.json();

      if (!data.loggedIn) { window.location.href = '/'; return; }
      if (data.user.role === 'admin') { window.location.href = '/admin.html'; return; }
      if (!data.hasTeam) { window.location.href = '/'; return; }
      if (data.banned) { window.location.href = '/banned.html'; return; }

      teamData = data.team;
      document.getElementById('team-name').textContent = data.team.team_name;
      document.getElementById('team-score').textContent = data.team.score;

      await loadProgress();
      startCountdown();
      setupRegionClicks();
    }

    // ── Load Progress ─────────────────────────────────────────────────────────
    async function loadProgress() {
      try {
        const res = await fetch('/api/progress');
        const data = await res.json();
        progressData = data.progress;
        document.getElementById('team-score').textContent = data.team.score;

        for (const cat of ['AI', 'CP', 'HEX', 'DEV']) {
          const p = progressData[cat] || { total: 0, solved: 0 };
          document.getElementById(`progress-${cat}`).textContent = `${p.solved}/${p.total}`;

          const regionPath = document.getElementById(`region-${cat}`);
          const stamp = document.getElementById(`stamp-${cat}`);
          const pulse = document.getElementById(`pulse-${cat}`);

          if (p.total > 0 && p.solved >= p.total) {
            regionPath.classList.add('completed');
            stamp.classList.add('show');
            pulse.classList.remove('active');
          } else {
            regionPath.classList.remove('completed');
            stamp.classList.remove('show');
            pulse.classList.add('active');
          }
        }
      } catch (e) {
        console.error('Failed to load progress:', e);
      }
    }

    // ── Countdown Timer ───────────────────────────────────────────────────────
    function startCountdown() {
      fetch('/api/competition-info').then(r => r.json()).then(data => {
        if (!data.end) {
          document.getElementById('countdown').textContent = '∞';
          return;
        }
        const endTime = new Date(data.end).getTime();

        function tick() {
          const now = Date.now();
          const diff = Math.max(0, endTime - now);
          const h = String(Math.floor(diff / 3600000)).padStart(2, '0');
          const m = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
          const s = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
          document.getElementById('countdown').textContent = `${h}:${m}:${s}`;
          if (diff > 0) requestAnimationFrame(tick);
          else document.getElementById('countdown').textContent = 'TIME UP';
        }
        tick();
      });
    }

    // ── Region Clicks ─────────────────────────────────────────────────────────
    function setupRegionClicks() {
      document.querySelectorAll('.region-group').forEach(group => {
        const category = group.dataset.category;
        group.querySelector('.region-path').addEventListener('click', () => {
          playClick();
          openCategoryPanel(category);
        });
      });
    }

    // ── Category Panel ────────────────────────────────────────────────────────
    async function openCategoryPanel(category) {
      currentCategory = category;
      document.getElementById('panel-category-title').textContent = category + ' — Questions';
      document.getElementById('question-panel').classList.add('open');
      document.getElementById('panel-backdrop').classList.add('open');
      showQuestionList();

      try {
        const res = await fetch(`/api/questions/${category}`);
        if (!res.ok) throw new Error('Failed');
        const questions = await res.json();
        renderQuestionList(questions);
      } catch (e) {
        document.getElementById('question-list').innerHTML = '<p style="color:#ff0040;">Failed to load questions.</p>';
      }
    }

    function closePanel() {
      document.getElementById('question-panel').classList.remove('open');
      document.getElementById('panel-backdrop').classList.remove('open');
      currentCategory = null;
      currentQuestionId = null;
    }

    document.getElementById('panel-backdrop').addEventListener('click', closePanel);

    function showQuestionList() {
      document.getElementById('question-list').style.display = 'block';
      document.getElementById('question-detail').classList.remove('active');
      if (currentCategory) openCategoryPanel(currentCategory);
    }

    function renderQuestionList(questions) {
      const container = document.getElementById('question-list');
      container.innerHTML = '';

      questions.forEach((q, i) => {
        const div = document.createElement('div');
        div.className = 'question-item' + (q.solved ? ' solved' : '') + (!q.unlocked ? ' locked' : '');
        div.innerHTML = `
          <div class="question-status ${q.solved ? 'solved' : ''} ${!q.unlocked ? 'locked' : ''}"></div>
          <span class="question-title">${i + 1}. ${q.title}</span>
          <span class="question-points">${q.points} pts</span>
        `;
        if (q.unlocked) {
          div.addEventListener('click', () => openQuestion(q.id));
        }
        container.appendChild(div);
      });
    }

    // ── Question Detail ───────────────────────────────────────────────────────
    async function openQuestion(questionId) {
      currentQuestionId = questionId;
      document.getElementById('question-list').style.display = 'none';
      document.getElementById('question-detail').classList.add('active');

      try {
        const res = await fetch(`/api/question/${questionId}`);
        if (!res.ok) throw new Error('Failed');
        const q = await res.json();
        renderQuestionDetail(q);
      } catch (e) {
        showToast('Failed to load question', 'error');
      }
    }

    function renderQuestionDetail(q) {
      document.getElementById('detail-title').textContent = q.title;
      document.getElementById('detail-points').textContent = q.points + ' pts';

      // Solved banner
      const banner = document.getElementById('detail-solved-banner');
      banner.style.display = q.solved ? 'block' : 'none';

      // Render markdown body
      const rendered = renderMarkdown(q.body_markdown);
      document.getElementById('detail-body').innerHTML = rendered;

      // Syntax highlighting
      document.querySelectorAll('#detail-body pre code').forEach(block => hljs.highlightElement(block));

      // Attachments
      const attContainer = document.getElementById('detail-attachments');
      attContainer.innerHTML = '';
      (q.attachments || []).forEach(a => {
        const link = document.createElement('a');
        link.className = 'attachment-btn';
        link.href = '/' + a.filepath;
        link.download = a.filename;
        link.innerHTML = `&#128196; ${a.filename}`;
        attContainer.appendChild(link);
      });

      // Reference links
      const linksContainer = document.getElementById('detail-links');
      linksContainer.innerHTML = '';
      (q.links || []).forEach(l => {
        const link = document.createElement('a');
        link.className = 'link-btn';
        link.href = l.url;
        link.target = '_blank';
        link.innerHTML = `&#128279; ${l.label}`;
        linksContainer.appendChild(link);
      });

      // Hints
      const hintsContainer = document.getElementById('detail-hints');
      hintsContainer.innerHTML = '';
      (q.hints || []).forEach((h, i) => {
        const box = document.createElement('div');
        box.className = 'hint-box';
        if (h.revealed) {
          // Need to fetch the hint text
          box.innerHTML = `<div class="hint-penalty">Hint ${i + 1} (${h.time_penalty}s penalty)</div><div class="hint-text" id="hint-text-${h.id}">Loading...</div>`;
          // Fetch revealed hint text
          fetch(`/api/reveal-hint/${h.id}`, { method: 'POST' }).then(r => r.json()).then(data => {
            document.getElementById(`hint-text-${h.id}`).textContent = data.hint_text;
          });
        } else {
          box.innerHTML = `
            <div class="hint-penalty">Hint ${i + 1} — Penalty: ${h.time_penalty}s</div>
            <button class="hint-reveal-btn" onclick="revealHint(${h.id}, this)">Reveal Hint</button>
          `;
        }
        hintsContainer.appendChild(box);
      });

      // Answer section
      const answerSection = document.getElementById('answer-section');
      answerSection.style.display = q.solved ? 'none' : 'block';

      // Attempt info
      document.getElementById('attempt-info').textContent = q.attempts > 0
        ? `${q.attempts} attempt(s) made`
        : '';

      // Clear inputs
      document.getElementById('answer-text-input').value = '';
      document.getElementById('answer-code-input').value = '';
    }

    // ── Markdown Rendering ────────────────────────────────────────────────────
    function renderMarkdown(md) {
      if (!md) return '';
      // Process LaTeX before markdown
      let text = md;
      // Block math: $$...$$ 
      text = text.replace(/\$\$([\s\S]+?)\$\$/g, (_, math) => {
        try { return '<div class="katex-block">' + katex.renderToString(math, { displayMode: true }) + '</div>'; }
        catch (e) { return '$$' + math + '$$'; }
      });
      // Inline math: $...$
      text = text.replace(/\$([^\$\n]+?)\$/g, (_, math) => {
        try { return katex.renderToString(math, { displayMode: false }); }
        catch (e) { return '$' + math + '$'; }
      });

      return marked.parse(text);
    }

    // ── Hint Reveal ───────────────────────────────────────────────────────────
    async function revealHint(hintId, btn) {
      if (!confirm('Revealing this hint will add a time penalty. Continue?')) return;

      try {
        const res = await fetch(`/api/reveal-hint/${hintId}`, { method: 'POST' });
        const data = await res.json();
        const box = btn.closest('.hint-box');
        btn.remove();
        const textEl = document.createElement('div');
        textEl.className = 'hint-text';
        textEl.textContent = data.hint_text;
        box.appendChild(textEl);
        if (data.penalty_applied) showToast(`Hint penalty: ${data.penalty_applied}s applied`, 'warning');
      } catch (e) {
        showToast('Failed to reveal hint', 'error');
      }
    }

    // ── Answer Mode Toggle ────────────────────────────────────────────────────
    function setAnswerMode(mode, btn) {
      document.querySelectorAll('.answer-toggle button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('answer-text-input').style.display = mode === 'text' ? 'block' : 'none';
      document.getElementById('answer-code-input').style.display = mode === 'code' ? 'block' : 'none';
    }

    // ── Submit Answer ─────────────────────────────────────────────────────────
    async function submitAnswer() {
      const textInput = document.getElementById('answer-text-input');
      const codeInput = document.getElementById('answer-code-input');
      const answer = textInput.style.display !== 'none' ? textInput.value : codeInput.value;

      if (!answer.trim()) { showToast('Enter an answer', 'warning'); return; }

      const spinner = document.getElementById('submit-spinner');
      const submitBtn = document.getElementById('submit-btn');
      submitBtn.disabled = true;
      spinner.style.display = 'inline-block';

      try {
        const res = await fetch(`/api/submit/${currentQuestionId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ answer: answer.trim() })
        });
        const data = await res.json();

        if (data.correct) {
          playSuccess();
          showToast(`Correct! +${data.points} points`, 'success');
          document.getElementById('detail-solved-banner').style.display = 'block';
          document.getElementById('answer-section').style.display = 'none';

          if (data.firstBlood) showToast('🩸 FIRST BLOOD!', 'success');
          if (data.categoryComplete) {
            showToast(`${currentCategory} NEUTRALIZED!`, 'success');
            launchConfetti();
          }

          document.getElementById('team-score').textContent = data.totalScore;
          await loadProgress();
        } else {
          playFail();
          showToast('Wrong answer. Try again.', 'error');
          // Flash red
          document.getElementById('question-detail').classList.add('flash-fail');
          setTimeout(() => document.getElementById('question-detail').classList.remove('flash-fail'), 600);
        }

        // Update attempt count
        const info = document.getElementById('attempt-info');
        const current = parseInt(info.textContent) || 0;
        info.textContent = `${current + 1} attempt(s) made`;

      } catch (e) {
        showToast('Submission failed', 'error');
      } finally {
        submitBtn.disabled = false;
        spinner.style.display = 'none';
      }
    }

    // ── Confetti ──────────────────────────────────────────────────────────────
    function launchConfetti() {
      const container = document.getElementById('confetti-container');
      for (let i = 0; i < 80; i++) {
        const particle = document.createElement('div');
        const x = Math.random() * 100;
        const delay = Math.random() * 0.5;
        const duration = 1.5 + Math.random() * 2;
        const size = 4 + Math.random() * 8;
        const colors = ['#00ff41', '#00cc33', '#004d00', '#00ff41', '#ffffff'];
        const color = colors[Math.floor(Math.random() * colors.length)];

        particle.style.cssText = `
          position: fixed; top: -10px; left: ${x}%;
          width: ${size}px; height: ${size}px;
          background: ${color};
          animation: confettiDrop ${duration}s ${delay}s ease-in forwards;
          pointer-events: none; z-index: 9999;
          transform: rotate(${Math.random() * 360}deg);
          opacity: 0.9;
        `;
        container.appendChild(particle);
        setTimeout(() => particle.remove(), (duration + delay) * 1000 + 100);
      }

      // Add the keyframe if not exists
      if (!document.getElementById('confetti-style')) {
        const style = document.createElement('style');
        style.id = 'confetti-style';
        style.textContent = `
          @keyframes confettiDrop {
            0% { transform: translateY(0) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
          }
        `;
        document.head.appendChild(style);
      }
    }

    // ── Toast ─────────────────────────────────────────────────────────────────
    function showToast(msg, type = 'info') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = 'toast' + (type === 'error' ? ' toast-error' : type === 'warning' ? ' toast-warning' : '');
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 4000);
    }

    // ── Logout ────────────────────────────────────────────────────────────────
    async function logout() {
      await fetch('/auth/logout', { method: 'POST' });
      window.location.href = '/';
    }

    // ── Socket.io Events ──────────────────────────────────────────────────────
    socket.on('announcement', (msg) => {
      const bar = document.getElementById('announcement-bar');
      bar.textContent = '📢 ' + msg;
      bar.classList.add('active');
      showToast('📢 ' + msg, 'warning');
    });

    socket.on('leaderboard_update', () => loadProgress());
    socket.on('maintenance', () => {
      showToast('Competition is under maintenance', 'warning');
    });

    // ── Start ─────────────────────────────────────────────────────────────────
    init();
  </script>
</body>
</html>
