<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DOOMSDAY — Team Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .dashboard-page {
      max-width: 1000px;
      margin: 0 auto;
      padding: 24px;
    }

    .dash-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      flex-wrap: wrap;
      gap: 16px;
    }
    .dash-header h1 { font-size: 24px; margin: 0; }
    .dash-team-info {
      text-align: right;
    }
    .dash-team-name {
      font-family: 'Orbitron', sans-serif;
      font-size: 14px;
      color: #00ff41;
    }
    .dash-team-score {
      font-family: 'Orbitron', sans-serif;
      font-size: 28px;
      font-weight: 900;
      color: #00ff41;
      text-shadow: 0 0 10px rgba(0,255,65,0.5);
    }
    .dash-team-id {
      font-size: 11px;
      color: #444;
    }

    .category-section {
      margin-bottom: 30px;
    }
    .category-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .category-header h3 {
      font-size: 16px;
      margin: 0;
    }
    .category-stats {
      font-family: 'Orbitron', sans-serif;
      font-size: 11px;
      color: #666;
    }

    .question-row {
      display: flex;
      align-items: center;
      padding: 10px 14px;
      border: 1px solid #1a1a1a;
      margin-bottom: 4px;
      gap: 12px;
      font-size: 13px;
    }
    .question-row.solved { border-left: 3px solid #00ff41; }
    .question-row.attempted { border-left: 3px solid #ffcc00; }
    .question-row.not-attempted { border-left: 3px solid #333; }

    .q-status-icon {
      width: 18px;
      font-size: 14px;
      text-align: center;
    }
    .q-title-col { flex: 1; }
    .q-meta {
      display: flex;
      gap: 16px;
      font-size: 11px;
      color: #666;
    }
    .q-meta span { white-space: nowrap; }
    .q-points-awarded {
      font-family: 'Orbitron', sans-serif;
      font-size: 12px;
      color: #00ff41;
      min-width: 60px;
      text-align: right;
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <a href="/" class="navbar-brand">DOOMSDAY</a>
    <div class="navbar-links">
      <a href="/gameboard.html">Gameboard</a>
      <a href="/leaderboard.html">Leaderboard</a>
      <a href="/dashboard.html" class="active">Dashboard</a>
    </div>
    <div class="navbar-user">
      <span id="user-name"></span>
      <button class="btn btn-small btn-danger" onclick="logout()" style="padding:4px 10px;font-size:9px;">Logout</button>
    </div>
  </nav>

  <div class="dashboard-page" id="dashboard-content">
    <div class="dash-header">
      <h1>Team Dashboard</h1>
      <div class="dash-team-info">
        <div class="dash-team-name" id="dash-team-name">—</div>
        <div class="dash-team-id" id="dash-team-id"></div>
        <div class="dash-team-score" id="dash-team-score">0</div>
      </div>
    </div>

    <div id="categories-container">
      <p style="color:#444;text-align:center;">Loading...</p>
    </div>
  </div>

  <div class="toast-container" id="toast-container"></div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();

    async function init() {
      const res = await fetch('/auth/me');
      const data = await res.json();
      if (!data.loggedIn) { window.location.href = '/'; return; }
      if (data.user.role === 'admin') { window.location.href = '/admin.html'; return; }
      if (!data.hasTeam) { window.location.href = '/'; return; }
      document.getElementById('user-name').textContent = data.team.team_name;
      loadDashboard();
    }

    async function loadDashboard() {
      try {
        const res = await fetch('/api/dashboard');
        const data = await res.json();

        document.getElementById('dash-team-name').textContent = data.team.name;
        document.getElementById('dash-team-id').textContent = 'ID: ' + data.team.id;
        document.getElementById('dash-team-score').textContent = data.team.score;

        const container = document.getElementById('categories-container');
        container.innerHTML = '';

        const categories = ['AI', 'CP', 'HEX', 'DEV'];
        for (const cat of categories) {
          const questions = data.categoryProgress[cat] || [];
          const solved = questions.filter(q => q.solved).length;
          const total = questions.length;
          const totalPoints = questions.reduce((sum, q) => sum + q.pointsAwarded, 0);
          const maxPoints = questions.reduce((sum, q) => sum + q.maxPoints, 0);

          const section = document.createElement('div');
          section.className = 'category-section';
          section.innerHTML = `
            <div class="category-header">
              <h3>${cat}</h3>
              <span class="category-stats">${solved}/${total} solved • ${totalPoints}/${maxPoints} pts</span>
            </div>
            <div class="progress-bar">
              <div class="progress-bar-fill" style="width:${total > 0 ? (solved/total*100) : 0}%"></div>
            </div>
          `;

          const list = document.createElement('div');
          list.style.marginTop = '12px';

          questions.forEach(q => {
            const status = q.solved ? 'solved' : (q.attempts > 0 ? 'attempted' : 'not-attempted');
            const icon = q.solved ? '✓' : (q.attempts > 0 ? '◯' : '—');
            const iconColor = q.solved ? '#00ff41' : (q.attempts > 0 ? '#ffcc00' : '#333');

            const row = document.createElement('div');
            row.className = `question-row ${status}`;
            row.innerHTML = `
              <span class="q-status-icon" style="color:${iconColor}">${icon}</span>
              <span class="q-title-col">${escapeHtml(q.title)}</span>
              <div class="q-meta">
                <span>Attempts: ${q.attempts}</span>
                <span>Hints: ${q.hintsUsed}</span>
                ${q.solvedAt ? `<span>Solved: ${new Date(q.solvedAt).toLocaleTimeString()}</span>` : ''}
              </div>
              <span class="q-points-awarded">${q.solved ? '+' + q.pointsAwarded : q.maxPoints + ' pts'}</span>
            `;
            list.appendChild(row);
          });

          section.appendChild(list);
          container.appendChild(section);
        }
      } catch (e) {
        console.error('Dashboard error:', e);
      }
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    async function logout() {
      await fetch('/auth/logout', { method: 'POST' });
      window.location.href = '/';
    }

    socket.on('announcement', (msg) => {
      showToast('📢 ' + msg, 'warning');
    });

    function showToast(msg, type = 'info') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = 'toast' + (type === 'error' ? ' toast-error' : type === 'warning' ? ' toast-warning' : '');
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 4000);
    }

    init();
  </script>
</body>
</html>
